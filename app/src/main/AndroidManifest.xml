<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network access for the local API server -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Foreground service to keep inference alive while app is in background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Notification for foreground service (required Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Model file access: legacy storage (API <= 32) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Model file access: scoped storage (API >= 33) -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

    <application
        android:name=".LamaPhoneApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LamaPhone"
        android:hardwareAccelerated="true"
        android:largeHeap="true">

        <!-- Optional native library for Adreno OpenCL GPU acceleration. -->
        <uses-native-library
            android:name="libOpenCL.so"
            android:required="false" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="unspecified"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".server.ApiService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
