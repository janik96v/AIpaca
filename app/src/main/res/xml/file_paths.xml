<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider paths configuration.
    Register the provider in AndroidManifest.xml when needed:

    <provider
        android:name="androidx.core.content.FileProvider"
        android:authorities="${applicationId}.fileprovider"
        android:exported="false"
        android:grantUriPermissions="true">
        <meta-data
            android:name="android.support.FILE_PROVIDER_PATHS"
            android:resource="@xml/file_paths" />
    </provider>
-->
<paths>
    <!-- Expose files from the app's external files dir (e.g. downloaded GGUF models) -->
    <external-files-path name="models" path="models/" />
    <!-- Expose files from external storage for user-selected model files -->
    <external-path name="external" path="." />
</paths>
